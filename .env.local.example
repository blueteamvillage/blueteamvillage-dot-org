# Copy to .env.local for local development. Never commit real values.

# --- Contentful (content delivery) ---
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=
# Shared secret Contentful sends in the x-revalidate-secret header of the
# publish webhook. Generate with: openssl rand -hex 32
CONTENTFUL_REVALIDATE_SECRET=

# --- Upstash Redis (cache layer) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=
# Local dev only — Vercel sets trust automatically:
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Google Workspace RBAC ---
# Workspace domain allowed to sign in
ALLOWED_GOOGLE_HD=blueteamvillage.org
# Service account with domain-wide delegation (directory group read-only)
GOOGLE_SA_CLIENT_EMAIL=
# base64 of the service account PEM private key:
#   jq -r .private_key key.json | base64
GOOGLE_SA_PRIVATE_KEY_B64=
# Workspace admin (or Groups Reader) the service account impersonates
GOOGLE_ADMIN_IMPERSONATION_SUBJECT=
